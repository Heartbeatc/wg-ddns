{
  "project": "us-entry-hk-exit",
  "cloudflare": {
    "zone": "example.com",
    "token": "",
    "token_env": "CLOUDFLARE_API_TOKEN",
    "record_type": "A",
    "ttl": 120,
    "proxied": false
  },
  "domains": {
    "entry": "us.example.com",
    "panel": "panel.example.com",
    "wireguard": "wg.example.com"
  },
  "nodes": {
    "us": {
      "role": "entry",
      "host": "1.2.3.4",
      "ssh": {
        "user": "root",
        "port": 22,
        "auth_method": "password",
        "password_env": "US_SSH_PASSWORD",
        "insecure_ignore_host_key": true
      },
      "wg_address": "10.66.66.1/24",
      "wg_port": 51820,
      "wg_private_key": "",
      "wg_public_key": "",
      "wg_config_path": "/etc/wireguard/wg0.conf",
      "wg_service": "wg-quick@wg0",
      "deploy": {
        "auto_install": true
      }
    },
    "hk": {
      "role": "exit",
      "host": "5.6.7.8",
      "ssh": {
        "user": "root",
        "port": 22,
        "auth_method": "password",
        "password_env": "HK_SSH_PASSWORD",
        "insecure_ignore_host_key": true
      },
      "wg_address": "10.66.66.2/24",
      "wg_private_key": "",
      "wg_public_key": "",
      "socks_listen": "10.66.66.2:10808",
      "proxy": "sing-box",
      "wg_config_path": "/etc/wireguard/wg0.conf",
      "wg_service": "wg-quick@wg0",
      "proxy_config_path": "/etc/sing-box/config.json",
      "proxy_service": "sing-box",
      "deploy": {
        "auto_install": true
      }
    }
  },
  "panel_guide": {
    "outbound_tag": "hk-socks",
    "route_user": "hk-test@local"
  },
  "healthcheck": {
    "test_url": "https://ifconfig.me",
    "exit_check_url": "https://ifconfig.me/country_code",
    "public_ip_check_url": "https://ifconfig.me/ip",
    "exit_location": "HK"
  }
}
